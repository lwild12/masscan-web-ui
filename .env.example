# Masscan Web UI — Environment Configuration
# Copy this file to .env and edit for bare-metal installs.
# Docker Compose reads these values directly from docker-compose.yml environment blocks.

# Database driver: 'mysql' (MySQL/MariaDB) or 'pgsql' (PostgreSQL)
DB_DRIVER=mysql

# Database host — use 'db' when running under Docker Compose
DB_HOST=127.0.0.1

DB_USERNAME=masscan
DB_PASSWORD=changem3
DB_DATABASE=masscan

# Docker Compose: root password for the MySQL container
DB_ROOT_PASSWORD=rootpassword

# Web port exposed on the host (Docker only)
WEB_PORT=8080

# Set to 'true' to show PHP errors (development only — never in production)
APP_DEBUG=false
